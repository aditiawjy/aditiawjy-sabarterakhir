{
  "manifest_version": 3,
  "name": "Sports Live Data Scraper",
  "version": "1.0",
  "description": "Scrapes live sports data from betting websites",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "downloads",
    "alarms"
  ],
  "host_permissions": [
    "https://prod20191-101527338.1x2aaa.com/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://prod20191-101527338.1x2aaa.com/en/asian-view/today/Virtual-Soccer*"
      ],
      "js": ["content.js"],
      "run_at": "document_end"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sports Scraper"
  }
}
